#!/bin/bash
set -e
PATTERNS=(
  'AIzaSy[A-Za-z0-9_-]{33}'
  'sk-ant-[A-Za-z0-9_-]{20,}'
  'sk-proj-[A-Za-z0-9_-]{20,}'
  'sk-svcacct-[A-Za-z0-9_-]{20,}'
  'xai-[A-Za-z0-9_-]{20,}'
  'sk-[A-Za-z0-9_-]{40,}'
  'ghp_[A-Za-z0-9]{36}'
  'gho_[A-Za-z0-9]{36}'
  'AKIA[0-9A-Z]{16}'
)
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '^(\.env|.*\.bak-|.*\.gitignore|.githooks/)' || true)
[ -z "$staged" ] && exit 0
hits=""
for pattern in "${PATTERNS[@]}"; do
  match=$(git diff --cached --unified=0 -- $staged 2>/dev/null | grep -E "^\+" | grep -oE "$pattern" | head -3 || true)
  if [ -n "$match" ]; then
    hits+="\n  Pattern: $pattern\n  Sample: $(echo "$match" | head -1 | cut -c1-30)…"
  fi
done
if [ -n "$hits" ]; then
  echo "" >&2
  echo "pre-commit: API-key patterns detected in staged changes" >&2
  echo -e "$hits" >&2
  echo "If intentional, rerun with: git commit --no-verify" >&2
  exit 1
fi
exit 0
